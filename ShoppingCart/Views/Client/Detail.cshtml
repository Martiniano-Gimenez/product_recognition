@using Model.Domain
@model Service.Data.ClientViewData


@{
    ViewBag.Title = "Detail";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-12">
            <h4 class="page-title text-center">CLIENTE</h4>
        </div>
    </div>
    <div class="row mt-2">
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.CUIL)
            @Html.EditorFor(Model => Model.CUIL, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.Name)
            @Html.EditorFor(Model => Model.Name, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.Seller)
            @Html.EditorFor(Model => Model.Seller, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.Email)
            @Html.EditorFor(Model => Model.Email, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.CellPhone)
            @Html.EditorFor(Model => Model.CellPhone, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.Telephone)
            @Html.EditorFor(Model => Model.Telephone, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-12 text-right">
            <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
        </div>
    </div>
}