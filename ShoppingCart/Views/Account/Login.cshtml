@model Service.Data.LoginData

@section Styles
{
    <link rel="stylesheet" href="~/css/login.styles.css">
    <link rel="stylesheet" href="~/lib/fontawesome-6.6.0/css/all.min.css">
}

<div class="row">
    <div class="offset-lg-4 col-lg-4 row-container">
        @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "loginForm" }))
        {
            @Html.AntiForgeryToken()
            <h1>INGRESO</h1>
            <span>
                @Html.TextBoxFor(model => model.UserName, new { @autocomplete = "off", @pattern = ".+", @placeholder = "Usuario" })
            </span>
            @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger", @style = "margin-top: 10px" })
            <span>
                @Html.PasswordFor(model => model.Password, new { @autocomplete = "off", @placeholder = "Contraseña", @style = "padding-right: 40px; width: 95%" })
                <span id="togglePassword" style="width: 5%; border-bottom: 1px solid rgb(211, 211, 211); margin-top: 30px; cursor: pointer">
                    <i class="fas fa-eye-slash"></i>
                </span>
            </span>
            @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger", @style = "margin-top: 10px" })
            <div id="partialMessages" class="alertMessage">
                @await Html.PartialAsync("_Messages")
            </div>
            <button class="btn" type="submit">Ingresar</button>
        }
    </div>
</div>

@section Scripts 
{
    <script type="text/javascript">
        $(document).ready(function () {
            $('#togglePassword').click(function () {
                var passwordField = $('#Password');
                var passwordFieldType = passwordField.attr('type');
                var icon = $(this).find('i');

                if (passwordFieldType === 'password') {
                    passwordField.attr('type', 'text');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                } else {
                    passwordField.attr('type', 'password');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                }
            });
        });

        setTimeout(ClosedSuccess, 4000);
        function ClosedSuccess() {
            $('#Messages').fadeOut('slow');
        }

        function trimUserName() {
            var userName = $("#@Html.IdFor(m => m.UserName)").val().trim();
            $("#@Html.IdFor(m => m.UserName)").val(userName)
        }
    </script>
}