@using Model.Domain
@using Service.Data
@using ShoppingCart.Helpers
@model Service.Data.DepositMovementData


@{
    ViewBag.Title = "Edit";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
}

@section Styles
{
    <link href="~/content/select2/css/select2.min.css" rel="stylesheet">
    <link href="~/content/sweet-alert2/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/css/tables.css" rel="stylesheet">
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-12">
            <h4 class="page-title text-center">NUEVO MOVIMIENTO</h4>
            @Html.HiddenFor(model => model.Id)
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-4">
            @Html.LabelFor(model => model.OriginDepositId)
            @Html.DropDownListFor(model => model.OriginDepositId, new SelectList(ViewBag.Deposits, "Key", "Value"), "Seleccione un depósito", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-4">
            @Html.LabelFor(model => model.DestinationDepositId)
            @Html.DropDownListFor(model => model.DestinationDepositId, new SelectList(ViewBag.Deposits, "Key", "Value"), "Seleccione un depósito", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-4">
            @Html.LabelFor(model => model.Date)
            @Html.EditorFor(Model => Model.Date, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-4 offset-md-4 text-center">
            <input type="file" name="Image" id="fileInput" accept="image/*" onchange="previewImage(event)" class="form-control mb-2" />

            <img id="imagePreview"
                 src="#"
                 alt="Previsualización"
                 style="display: none; width: 350px; height: 350px; object-fit: cover; border: 1px solid #ccc; margin-top: 10px; border-radius: 8px;" />
        </div>
    </div>
    <div class="row mt-3">
        <div class="form-group col-md-12 text-center">
            <button type="button"
                    id="btnDetectProducts"
                    class="btn btn-info btn-sm"
                    onclick="detectProductsFromOrder()"
                    style="font-size: 1rem; font-weight: bold;">
                <i class="fa-solid fa-eye"></i> Reconocer productos en imagen
            </button>
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-9">
            @Html.LabelFor(model => model.NewProductId)
            @Html.DropDownListFor(model => model.NewProductId, new SelectList(new List<KeyValueData>(), "Key", "Value"), "Seleccione un artículo", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-2">
            @Html.LabelFor(model => model.NewProductQuantity)
            @Html.EditorFor(model => model.NewProductQuantity, new
                {
                    htmlAttributes = new
                    {
                        @class = "form-control text-center productInput number",
                        @step = "1",
                        @min = "1",
                        @pattern = "[0-9]*",
                    }
                })
        </div>
        <div class="form-group col-md-1 align-content-end">
            <button type="button" onclick="addProduct()" class="btn btn-primary btn-sm w-100" title="Agregar artículo" style="font-size: 1rem; font-weight: bold; height: 38px;">
                <i class="fa-solid fa-plus"></i>
            </button>
        </div>
    </div>
    <div class="row" id="productsContainer">
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card cart-summary shadow-sm border-0">
                <div class="card-body p-2" style="border: 2px solid #221109">
                    <div class="row align-items-center">
                        <div class="col-md-9 mb-2 mb-md-0">
                            @Html.TextAreaFor(model => model.Observation, new { @class = "form-control", @style = "width: 100%; resize: none; height: 42px; font-size: 15px; padding: 4px", @placeholder = "Observación..." })
                        </div>
                        <div class="col-md-3">
                            <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm w-100 p-0 mb-1" style="font-size: 1rem; font-weight: bold;">Volver</a>
                            <button type="button" onclick="edit()" class="btn btn-warning btn-sm w-100 p-0" style="font-size: 1rem; font-weight: bold;">
                                Guardar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts
{
    <script src="~/content/select2/js/select2.min.js"></script>
    <script src="~/content/select2/js/i18n/es.js"></script>
    <script src="~/content/sweet-alert2/js/sweetalert2.all.min.js"></script>

    <script>
        function previewImage(event) {
          const input = event.target;
          const preview = document.getElementById('imagePreview');

          if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function (e) {
              preview.src = e.target.result;
              preview.style.display = 'block';
            };

            reader.readAsDataURL(input.files[0]);
          } else {
            preview.src = '#';
            preview.style.display = 'none';
          }
        }

        function detectProductsFromOrder() {
            const input = document.getElementById("fileInput");
            const preview = document.getElementById("imagePreview");

            if (!input.files || input.files.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Sin imagen',
                    text: 'Debe seleccionar una imagen antes de detectar productos.',
                    confirmButtonText: 'Aceptar'
                });
                return;
            }

            const form = $('form')[0];
            const formData = new FormData(form);

            Swal.fire({
                title: 'Procesando imagen...',
                text: 'Esto puede tardar unos segundos.',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            $.ajax({
                url: '@Url.Action("DetectProducts")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (html) {
                    Swal.close();
                    var container = $("#productsContainer");
                    container.empty();
                    container.html(html);
                    removeImage();
                    Swal.fire({
                        icon: 'success',
                        title: 'Productos detectados',
                        text: 'Se agregaron automáticamente al pedido.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                },
                error: function (xhr) {
                    removeImage();
                    Swal.close();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error al detectar',
                        text: xhr.responseText || 'No se pudo procesar la imagen.',
                        confirmButtonText: 'Aceptar'
                    });
                }
            });
        }

        function removeImage() {
            const fileInput = document.getElementById('fileInput');
            const image = document.getElementById('imagePreview');

            fileInput.value = '';           // Limpia el input file
            image.src = '#';                // Limpia la imagen
            image.style.display = 'none';   // Oculta la vista previa
        }


        $(document).ready(function () {
            $('#OriginDepositId').select2({
                placeholder: 'Seleccione un depósito',
                allowClear: true,
                language: 'es',
                width: "100%"
            });

            $('#DestinationDepositId').select2({
                placeholder: 'Seleccione un depósito',
                allowClear: true,
                language: 'es',
                width: "100%"
            });

             $('#NewProductId').select2({
                allowClear: true,
                language: 'es',
                width: "100%",
                placeholder: "Seleccione un artículo",
                multiple: false,
                minimumInputLength: 2,
                delay: 50, 
                ajax: {
                    url: "@Url.Action("GetProductsByTerm")", 
                    dataType: 'json',
                    type: "GET",
                    data: function(params) {
                        return {
                            term: params.term
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: $.map(data, function(item) {
                                return {
                                    id: item.Key,  
                                    text: item.Value 
                                };
                            })
                        };
                    }
                }
            });
        })

        function addProduct() {
            if (!($('#NewProductId').val() > 0) || !($('#NewProductQuantity').val() > 0)) {
                Swal.fire({
                    title: '¡Atención!',
                    text: 'Debe seleccionar artículo y cantidad para agregar.',
                    icon: 'warning',
                    confirmButtonText: 'Aceptar'
                });
                return;
            }

            var data = $('form').serialize();
            $.ajax({
                url: '@Url.Action("AddProductToDepositMovement")',
                type: 'POST',
                data: data,
                success: function (data) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Éxito',
                        text: 'Se ha agregado correctamente el item',
                        timer: 1500,
                        showConfirmButton: false
                    });
                    var selector = $("#productsContainer");
                    selector.empty();
                    selector.html(data);
                    $('#NewProductId').val('').trigger('change');
                    $('#NewProductQuantity').val('');

                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'No se ha podido agregar el item',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            });
        }

        function updateDepositMovement() {
            var data = $('form').serialize();
            $.ajax({
                url: '@Url.Action("UpdateDepositMovement")',
                type: 'POST',
                data: data,
                success: function (data) {
                    var selector = $("#productsContainer");
                    selector.empty();
                    selector.html(data);
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'No se ha podido actualizar el movimiento',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            });
        }

        function deleteProduct(productId) {
            Swal.fire({
                title: "¿Está seguro de eliminar este item?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success', 
                    cancelButton: 'btn btn-danger mr-2'    
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    var data = $('form').serialize();
                    $.ajax({
                        url: '@Url.Action("DeleteProduct")?productId=' + productId,
                        type: 'POST',
                        data: data,
                        success: function (data) {
                            var selector = $("#productsContainer");
                            selector.empty();
                            selector.html(data);
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'No se ha podido eliminar el item',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    });
                }
            });
        }

        function edit() {
            Swal.fire({
                title: "¿Está seguro desea actualizar el movimiento?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger mr-2'
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    beginWait($('form'))
                    $('form').submit();
                }
            });
        }
    </script>
}
