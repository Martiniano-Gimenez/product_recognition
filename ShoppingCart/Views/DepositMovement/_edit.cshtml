@model Service.Data.DepositMovementData

<div class="col-lg-12" style="overflow: auto">
    <table class="table table-striped table-bordered table-hover" width="100%">
        <thead>
            <tr>
                <th class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">Nombre</th>
                <th class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">Cant.</th>
                <th class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @for (int productIndex = 0; productIndex < Model.Products.Count; productIndex++)
            {
                <tr>
                    @Html.HiddenFor(model => model.Products[productIndex].Id)
                    @Html.HiddenFor(model => model.Products[productIndex].ProductId)
                    @Html.HiddenFor(model => model.Products[productIndex].Name)
                    <td class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">
                        @Html.DisplayFor(model => model.Products[productIndex].Name)
                    </td>
                    <td class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">
                        @Html.EditorFor(model => model.Products[productIndex].Quantity, new
                            {
                                htmlAttributes = new
                                {
                                    @class = "text-center productInput number w-100",
                                    @step = "1",
                                    @min = "1",
                                    @pattern = "[0-9]*",
                                    onchange = $"updateOrder()"
                                }
                            })
                    </td>
                    <td class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteProduct(@Model.Products[productIndex].ProductId)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="3">
                        No hay artículos
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>