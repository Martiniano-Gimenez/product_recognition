@using Model.Domain
@using Service.Data
@using ShoppingCart.Helpers
@model Service.Data.CartData


@{
    ViewBag.Title = "Cart";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
    var isClient = false;
}

@section Styles
{
    <link href="~/content/datatable/datatables.min.css" rel="stylesheet">
    <link href="~/content/sweet-alert2/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/content/select2/css/select2.min.css" rel="stylesheet">
}

@using (Html.BeginForm("Create", "ShoppingCart", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-12">
            <h4 class="page-title text-center">PEDIDO ACTUAL</h4>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <h6 class="text-center fw-bold mt-3 mb-3 p-2 bg-warning text-dark rounded shadow-sm">
                LOS PRECIOS UNITARIOS DE CADA ARTÍCULO SON NETOS
            </h6>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-12">
            <div id="partialMessages" style="height:40px">
                @await Html.PartialAsync("_Messages")
            </div>
        </div>
    </div>
    <div class="row mb-3 mt-2">
        <div class="form-group col-md-8">
            @Html.LabelFor(model => model.ClientId)
            @Html.DropDownListFor(model => model.ClientId, new SelectList(ViewBag.Clients, "Key", "Value"), "Seleccione un cliente", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-4">
            @Html.LabelFor(model => model.Date)
            @Html.EditorFor(Model => Model.DateDisplay, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="row align-items-start g-3">
                <div class="col-12 col-md-4">
                    <input type="file"
                           id="fileInput"
                           accept="image/*"
                           onchange="previewImage(event)"
                           style="display: none;" />
                    <button type="button"
                            onclick="document.getElementById('fileInput').click()"
                            class="btn btn-info btn-sm w-100 mb-2"
                            title="Tomar foto"
                            style="font-size: 1rem; font-weight: bold; height: 48px;">
                        Tomar foto <i class="fa-solid fa-camera ms-2"></i>
                    </button>
                    <button type="button"
                            id="btnEliminar"
                            class="btn btn-danger btn-sm w-100 mb-2"
                            onclick="clearImage()"
                            disabled
                            style="font-size: 1rem; font-weight: bold; height: 48px;">
                        Eliminar imagen
                    </button>
                    <button type="button"
                            id="btnBuscar"
                            class="btn btn-primary btn-sm w-100"
                            onclick="document.getElementById('fileInput').click()"
                            disabled
                            style="font-size: 1rem; font-weight: bold; height: 48px;">
                        Buscar productos
                    </button>
                </div>
                <div class="col-12 col-md-4 text-center" id="imageContainer" style="display: none;">
                    <img id="imagePreview"
                         src="#"
                         alt="Previsualización"
                         class="img-fluid border rounded"
                         style="width: 100%; max-height: 400px; object-fit: contain;" />
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-9">
            @Html.LabelFor(model => model.NewProductId)
            @Html.DropDownListFor(model => model.NewProductId, new SelectList(new List<KeyValueData>(), "Key", "Value"), "Seleccione un artículo", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-2">
            @Html.LabelFor(model => model.NewProductQuantity)
            @Html.EditorFor(model => model.NewProductQuantity, new
                {
                    htmlAttributes = new
                    {
                        @class = "form-control text-center productInput number",
                        @step = "1",
                        @min = "1",
                        @pattern = "[0-9]*",
                    }
                })
        </div>
        <div class="form-group col-md-1 align-content-end">
            <button type="button" onclick="addProduct()" class="btn btn-primary btn-sm w-100" title="Agregar artículo" style="font-size: 1rem; font-weight: bold; height: 38px;">
                <i class="fa-solid fa-plus"></i>
            </button>
        </div>
    </div>
    <div class="row" id="cartContainer">
        @await Html.PartialAsync("_cart", Model)
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="card cart-summary shadow-sm border-0">
                <div class="card-body p-2" style="border: 2px solid #221109">
                    <div class="row align-items-center">
                        <div class="col-md-9 mb-2 mb-md-0">
                            @Html.TextAreaFor(model => model.Observation, new { @class = "form-control", @style = "width: 100%; resize: none; height: 42px; font-size: 15px; padding: 4px", @placeholder = "Observación..." })
                        </div>
                        <div class="col-md-3">
                            <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm w-100 p-0 mb-1" style="font-size: 1rem; font-weight: bold;">Continuar comprando</a>
                            @if (!Model.Products.Any())
                            {
                                <button type="button" disabled class="btn btn-warning btn-sm w-100 p-0" style="font-size: 1rem; font-weight: bold;">
                                    Confirmar
                                </button>
                            }
                            else
                            {
                                if (isClient)
                                {
                                    <button type="button" onclick="sendOrder()" class="btn btn-warning btn-sm w-100 p-0" style="font-size: 1rem; font-weight: bold;">
                                        Confirmar
                                    </button>
                                }
                                else
                                {
                                    <button type="button" onclick="sendNoClientOrder()" class="btn btn-warning btn-sm w-100 p-0" style="font-size: 1rem; font-weight: bold;">
                                        Confirmar
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts
{
    <script src="~/content/datatable/datatables.min.js"></script>
    <script src="~/content/sweet-alert2/js/sweetalert2.all.min.js"></script>
    <script src="~/content/select2/js/select2.min.js"></script>
    <script src="~/content/select2/js/i18n/es.js"></script>


    <script>
              function previewImage(event) {
          const input = event.target;
          const preview = document.getElementById('imagePreview');
          const container = document.getElementById('imageContainer');
          const btnEliminar = document.getElementById('btnEliminar');
          const btnBuscar = document.getElementById('btnBuscar');

          if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function (e) {
              preview.src = e.target.result;
              preview.style.display = 'block';
              container.style.display = 'block';

              // Habilitar botones
              btnEliminar.disabled = false;
              btnBuscar.disabled = false;
            };

            reader.readAsDataURL(input.files[0]);
          }
        }

        function clearImage() {
          const input = document.getElementById('fileInput');
          const preview = document.getElementById('imagePreview');
          const container = document.getElementById('imageContainer');
          const btnEliminar = document.getElementById('btnEliminar');
          const btnBuscar = document.getElementById('btnBuscar');

          input.value = '';
          preview.src = '#';
          preview.style.display = 'none';
          container.style.display = 'none';

          // Deshabilitar botones
          btnEliminar.disabled = true;
          btnBuscar.disabled = true;
        }


        $(document).ready(function () {
            $('#ClientId').select2({
                placeholder: 'Seleccione un cliente',
                allowClear: true,
                language: 'es',
                width: "100%"
            });

             $('#NewProductId').select2({
                allowClear: true,
                language: 'es',
                width: "100%",
                placeholder: "Seleccione un artículo",
                multiple: false,
                minimumInputLength: 2,
                delay: 50,
                ajax: {
                    url: "@Url.Action("GetProductsByTerm")",
                    dataType: 'json',
                    type: "GET",
                    data: function(params) {
                        return {
                            term: params.term
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: $.map(data, function(item) {
                                return {
                                    id: item.Key,
                                    text: item.Value
                                };
                            })
                        };
                    }
                }
            });
        })

        function addProduct() {
            var productId = $('#NewProductId').val();
            var quantity = $('#NewProductQuantity').val();


            if (!(productId > 0) || !(quantity > 0)) {
                Swal.fire({
                    title: '¡Atención!',
                    text: 'Debe seleccionar artículo y cantidad para agregar.',
                    icon: 'warning',
                    confirmButtonText: 'Aceptar'
                });
                return;
            }

            $.ajax({
                url: '@Url.Action("AddProductToCart")?productId=' + productId + '&quantity=' + quantity,
                type: 'POST',
                success: function (data) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Éxito',
                        text: 'Se ha agregado correctamente el item',
                        timer: 1500,
                        showConfirmButton: false
                    });
                    var selector = $("#cartContainer");
                    selector.empty();
                    selector.html(data);
                    $('#NewProductId').val('').trigger('change');
                    $('#NewProductQuantity').val('');

                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'No se ha podido agregar el item',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            });
        }

        function sendNoClientOrder() {
            if (!($('#ClientId').val() > 0)) {
                Swal.fire({
                    title: '¡Atención!',
                    text: 'Debe seleccionar un cliente para continuar.',
                    icon: 'warning',
                    confirmButtonText: 'Aceptar'
                });
                return;
            }


            Swal.fire({
                title: "¿Está seguro desea enviar este pedido?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger mr-2'
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    beginWait($('#cartContainer'))
                    $('form').submit();
                }
            });
        }

        function sendOrder() {
            Swal.fire({
                title: "¿Está seguro desea enviar este pedido?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger mr-2'
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    beginWait($('#cartContainer'))
                    $('form').submit();
                }
            });
        }

        function changeProductCartQuantity(productId, elem) {
            var quantity = elem.value;
            $.ajax({
                url: '@Url.Action("ChangeProductCartQuantity")?productId=' + productId + '&quantity=' + quantity,
                type: 'POST',
                success: function (data) {
                    var selector = $("#cartContainer");
                    selector.empty();
                    selector.html(data);
                },
                error: function (jqXHR) {
                    $(elem).val('');

                    let errorMessage = "Ocurrió un error inesperado";
                    if (jqXHR.responseJSON && jqXHR.responseJSON.error) {
                        errorMessage = jqXHR.responseJSON.error;
                    }

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: errorMessage,
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            });
        }

        function deleteProduct(productId) {
            Swal.fire({
                title: "¿Está seguro de eliminar este item?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger mr-2'
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteProductFromCart")?productId=' + productId,
                        type: 'POST',
                        success: function (data) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Éxito',
                                text: 'Se ha eliminado correctamente el item',
                                timer: 1500,
                                showConfirmButton: false
                            });
                            var selector = $("#cartContainer");
                            selector.empty();
                            selector.html(data);
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'No se ha podido eliminar el item',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    });
                }
            });
        }
    </script>
}