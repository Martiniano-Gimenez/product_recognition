@{
    ViewBag.Title = "Index";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
}

@section Styles
{
    <link href="~/content/datatable/datatables.min.css" rel="stylesheet">
    <link href="~/content/sweet-alert2/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/content/select2/css/select2.min.css" rel="stylesheet">
    <link href="~/css/shoppingCartAddBtn.css" rel="stylesheet">
    <link href="~/css/tables.css" rel="stylesheet">
}

<div class="row">
    <div class="col-md-12">
        <h6 class="text-center fw-bold mb-3 p-2 bg-warning text-dark rounded shadow-sm">
            LOS PRECIOS QUE SE VISUALIZAN EN ESTA TABLA SON NETOS
        </h6>
    </div>
</div>
<div class="row">
 @*    <div class="form-group col-md-6">
        @Html.Label("Grupo")
        @Html.DropDownList("GroupId", new SelectList(ViewBag.Groups, "Key", "Value"), "Seleccione un grupo", new { @class = "form-control", @onchange = "filterGrid()" })
    </div>
    <div class="form-group col-md-6">
        @Html.Label("Categoría")
        @Html.DropDownList("CategoryId", new SelectList(ViewBag.Categories, "Key", "Value"), "Seleccione una categoría", new { @class = "form-control", @onchange = "filterGrid()" })
    </div> *@
</div>
<div class="row">
    <div class="col-md-12">
        <table id="Grid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Código</th>
                    <th class="text-center">Nombre</th>
                    <th class="text-center">Precio</th>
                </tr>
            </thead>
        </table>
    </div>
    <div class="card w-100 mt-1 p-0" style="position: -webkit-sticky; position: sticky; bottom: 0; z-index: 1030;">
        <div class="card-header p-0">
            <h5 class="mb-0">
                <button style="display: flex; align-items: center; justify-content: space-between; width: 100%; border-radius: 0" class="btn btn-warning" type="button"
                        data-toggle="collapse" data-target="#collapseCard" aria-expanded="true" aria-controls="collapseCard">
                    <span style="font-weight: bold">IMÁGENES Y DETALLES</span>
                    <i style="font-size: 1.2rem; transition: transform 0.3s ease;" class="fa-solid fa-angles-up"></i>
                </button>
            </h5>
        </div>
        <div id="collapseCard" class="collapse show">
            <div class="card-body p-1" id="productDetailContainer" style="background-color: #221109">
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/content/datatable/datatables.min.js"></script>
    <script src="~/content/sweet-alert2/js/sweetalert2.all.min.js"></script>
    <script src="~/content/select2/js/select2.min.js"></script>
    <script src="~/content/select2/js/i18n/es.js"></script>

    <script>
        $(document).ready(function () {
            $('#CategoryId').select2({
                placeholder: 'Seleccione una categoría',
                allowClear: true,
                language: 'es',
                width: "100%"
            });

            $('#GroupId').select2({
                placeholder: 'Seleccione un grupo',
                allowClear: true,
                language: 'es',
                width: "100%"
            });

            var grid = $('#Grid').DataTable({
                "processing": true,
                "serverSide": true,
                "responsive": {
                    details: false
                },
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "select": {
                    style: 'single',
                    toggleable: false,
                    info: false
                },
                "ajax": {
                    "url": "@Url.Action("Grid", controllerName)",
                    "type": "POST",
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) { return data = JSON.stringify(data); }
                },
                "columns": [
                    { "data": "Code", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Name", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Actions", "responsivePriority": 1, "className": "text-center" },
                ],
                "language": {
                    "decimal": ",",
                    "emptyTable": "No hay datos disponibles en la tabla",
                    "info": "_START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "0 a 0 de 0 registros",
                    "infoFiltered": "(filtrado de _MAX_ registros en total)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Mostrar _MENU_ registros",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "searchPlaceholder": "Buscar por código, nombre o descripción...",
                    "zeroRecords": "No se encontraron registros coincidentes",
                    "paginate": {
                        "first": "<<",
                        "last": ">>",
                        "next": ">",
                        "previous": "<"
                    }
                },
                "columnDefs": [
                    {
                        "targets": [-1],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var detail = `
                                <div class="row">
                                    <div class="col-md-4">
                                        <input value="${rowData.Units}" onchange="getProductPrice(${rowData.Id}, this)" class="number text-center" id="quantity_input_product_${rowData.Id}" style="width: 60px" min="1" step="1" pattern="[0-9]*" />
                                        ${rowData.ShowOffersAsStringForTooltip ? `
                                        <span data-toggle="tooltip" data-placement="top" data-html="true" title="${rowData.OffersAsStringForTooltip}">
                                            <i class="fa-solid fa-circle-info btn-agregar fs-5" 
                                                style="padding-left: 4px !important;padding-right: 4px !important;cursor: pointer !important"></i>
                                        </span>` : ''}
                                    </div>
                                    <div class="col-md-4">
                                        <span id="price_product_${rowData.Id}">${rowData.Price}</span>
                                    </div>
                                     <div class="col-md-4">
                                        <button class='btn btn-sm btn-agregar' title='Agregar' onclick='addToOrder(${rowData.Id})'><i class='fa-solid fa-circle-plus icon-agregar'></i> Agregar</button >
                                    </div>
                                </div>
                            `;
                            $(td).append(detail);
                            $(td).find('[data-toggle="tooltip"]').tooltip();
                        }
                    }
                ],
                drawCallback: function (settings) {
                    if (grid.rows({ selected: true }).count() === 0) {
                        grid.rows(0).select();
                    }
                }
            });

            grid.on('draw', function () {
                parseNumber();
            });

            grid.on('select', function (e, dt, type, indexes) {
                getProductDetail(grid.row(indexes[0]).data().Id);
            });

            $("#Grid_filter input")
                .unbind()
                .bind("input", function (e) {
                    
                    if (this.value.length >= 3) {

                        grid.search(this.value).draw();
                    }
                    if (this.value == "") {
                        grid.search("").draw();
                    }
                    return;
                });
        });

        function filterGrid() {
            var groupId = $('#GroupId').val();
            var categoryId = $('#CategoryId').val();

            var grid = $('#Grid').DataTable();

            grid.column(0).search(groupId);
            grid.column(1).search(categoryId).draw();
        }

        function getProductDetail(id) {
            $.ajax({
                url: '@Url.Action("GetProductDetail")?productId=' + id,
                type: 'POST',
                success: function (data) {
                    var selector = $("#productDetailContainer");
                    selector.empty();
                    selector.html(data);
                }
            });
        }

        function getProductPrice(productId, elem) {
            var quantity = $(elem).val();
            $.ajax({
                url: '@Url.Action("GetProductPriceByQuantity")?productId=' + productId + '&quantity=' + quantity,
                type: 'POST',
                success: function (data) {
                    var selector = $("#price_product_" + productId)
                    selector.empty();
                    selector.text(data.price);
                },
                error: function (jqXHR) {
                    $(elem).val('');

                    let errorMessage = "Ocurrió un error inesperado";
                    if (jqXHR.responseJSON && jqXHR.responseJSON.error) {
                        errorMessage = jqXHR.responseJSON.error;
                    }

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: errorMessage,
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            })
        }

        function addToOrder(productId) {
            var quantity = $('#quantity_input_product_' + productId).val();
            if(quantity < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Debe ingresar la cantidad de unidades que desea agregar (número mayor a 0)',
                });
                return;
            }

            $.ajax({
                url: '@Url.Action("AddProductToCart")?productId=' + productId + '&quantity=' + quantity,
                type: 'POST',
                success: function (result) {
                    if (result) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Éxito',
                            text: 'Se ha agregado correctamente su pedido',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'No se ha podido agregar a su pedido',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    }
                }
            });
        }

</script>
}