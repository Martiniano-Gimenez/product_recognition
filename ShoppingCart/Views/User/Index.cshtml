@using Model.Domain

@{
    ViewBag.Title = "Index";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
}

@section Styles
{
    <link href="~/content/datatable/datatables.min.css" rel="stylesheet">
    <link href="~/content/sweet-alert2/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/css/tables.css" rel="stylesheet">
}

<div class="row">
    <div class="col-md-12">
        <h4 class="page-title text-center">USUARIOS</h4>
    </div>
</div>
<div class="row mb-3">
    <div class="col-md-12">
        <div id="partialMessages" style="height:40px">
            @await Html.PartialAsync("_Messages")
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-12 form-group text-right">
        <a href="@Url.Action("Create")" class="btn btn-primary">Agregar <i class="fa-solid fa-plus"></i></a>
    </div>
    <div class="col-md-12">
        <table id="Grid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Usuario</th>
                    <th class="text-center">Rol</th>
                    <th class="text-center">Cliente/Vendedor</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts
{
    <script src="~/content/datatable/datatables.min.js"></script>
    <script src="~/content/sweet-alert2/js/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function () {
            var grid = $('#Grid').DataTable({
                "processing": true,
                "serverSide": true,
                responsive: {
                    details: {
                        type: 'inline',
                        renderer: function (api, rowIdx, columns) {
                            var data = $.map(columns, function (col) {
                                return col.hidden
                                    ? `
                                <div class="detail-item">
                                    <span class="detail-title">${col.title}:</span>
                                    <span class="detail-data">${col.data}</span>
                                </div>
                                `
                                    : '';
                            }).join('');
                            return data ? `<div class="details-container">${data}</div>` : false;
                        }
                    }
                },
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("Grid", controllerName)",
                    "type": "POST",
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) { return data = JSON.stringify(data); }
                },
                "order": [[0, "desc"]],
                "columns": [
                    { "data": "UserName", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Role", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Name", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Actions", "responsivePriority": 1, "className": "text-center" },
                ],
                "language": {
                    "decimal": ",",
                    "emptyTable": "No hay datos disponibles en la tabla",
                    "info": "_START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "0 a 0 de 0 registros",
                    "infoFiltered": "(filtrado de _MAX_ registros en total)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Mostrar _MENU_ registros",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "searchPlaceholder": "Buscar...",
                    "zeroRecords": "No se encontraron registros coincidentes",
                    "paginate": {
                        "first": "<<",
                        "last": ">>",
                        "next": ">",
                        "previous": "<"
                    }
                },
                "columnDefs": [
                    {
                        "targets": [-1],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var resetPassword = "<button type='button' class='btn btn-sm btn-success mb-1 mr-1' onclick='resetPassword(" + rowData.Id + ")'> Reiniciar contraseña</button > ";
                            $(td).css("text-align", "center");
                            $(td).append(resetPassword);
                        }
                    }
                ]
            });

            grid.on('order', function () {
                var order = grid.order();
                if (!order || order.length === 0) {
                    table.order([[0, 'desc']]).draw();
                }
            });

            $("#Grid_filter input")
                .unbind()
                .bind("input", function (e) {
                    
                    if (this.value.length >= 3) {

                        grid.search(this.value).draw();
                    }
                    if (this.value == "") {
                        grid.search("").draw();
                    }
                    return;
                });
        });

        function resetPassword(id) {
            Swal.fire({
                title: "¿Está seguro que desea reiniciar la contraseña del usuario?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger mr-2'
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ResetPassword")?userId=' + id,
                        type: 'POST',
                        success: function (result) {
                            if (result) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Éxito',
                                    text: 'La contraseña se reinició con éxito',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'Ocurrió un error al reiniciar la contraseña',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Ocurrió un error al reiniciar la contraseña',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    });
                }
            });
        }
    </script>
}