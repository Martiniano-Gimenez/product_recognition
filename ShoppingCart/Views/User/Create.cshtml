@model Service.Data.UserData


@{
    ViewBag.Title = "Create";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-12">
            <h4 class="page-title text-center">USUARIO</h4>
            @Html.HiddenFor(model => model.UserId)
        </div>
    </div>
    <div class="row mt-2">
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.UserName)
            @Html.EditorFor(Model => Model.UserName, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-6">
            @Html.LabelFor(model => model.RoleId)
            @Html.DropDownListFor(model => model.RoleId, new SelectList(ViewBag.Roles, "Key", "Value"), "Seleccione un rol", new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.RoleId, "", new { @class = "text-danger" })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-12 text-right">
            <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
            <button class="btn btn-primary">Guardar</button>
        </div>
    </div>
}