@using Model.Domain
@using ShoppingCart.Helpers
@model Service.Data.OrderViewData


@{
    ViewBag.Title = "Detail";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
    var isAdmin = User.GetRoleId() == (short)eRole.Administrator;
}

@section Styles
{
    <link href="~/content/datatable/datatables.min.css" rel="stylesheet">
    <link href="~/css/tables.css" rel="stylesheet">
}

<div class="row">
    <div class="col-md-12">
        <h4 class="page-title text-center">PEDIDO @Model.Id</h4>
    </div>
</div>
<div class="row">
    <div class="form-group @(isAdmin ? "col-md-4" : "col-md-6")">
        @Html.LabelFor(model => model.Client)
        @Html.EditorFor(Model => Model.Client, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
    </div>
    @if (isAdmin)
    {
        <div class="form-group col-md-4">
            @Html.LabelFor(model => model.Seller)
            @Html.EditorFor(Model => Model.Seller, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
        </div>
    }
    <div class="form-group @(isAdmin ? "col-md-4" : "col-md-6")">
        @Html.LabelFor(model => model.Date)
        @Html.EditorFor(Model => Model.Date, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled"} })
    </div>
</div>
<div class="row">
    <div class="form-group col-md-12">
        @Html.LabelFor(model => model.Observation)
        @Html.TextAreaFor(Model => Model.Observation, new { @class = "form-control", @disabled = "disabled", @style = "width: 100%; resize: none; height: 80px; padding: 4px"  })
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <h5 class="page-title-sm text-center">DETALLES</h5>
    </div>
</div>
<div class="row">
    <div class="form-group col-md-12">
        <table id="Grid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Nombre</th>
                    <th class="text-center">Precio U.</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-center">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td class="text-center">@product.Code - @product.Name</td>
                        <td class="text-center">@product.UnitPriceDisplay</td>
                        <td class="text-center">@product.Quantity</td>
                        <td class="text-center">@product.TotalDisplay</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-center">@Html.DisplayNameFor(model => model.Total)</th>
                    <th class="text-center">@Html.DisplayFor(Model => Model.DisplayTotal)</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <h5 class="page-title-sm text-center">HISTORIAL DE ESTADOS</h5>
    </div>
</div>
<div class="row">
    <div class="form-group col-md-12">
        <table id="Grid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Fecha</th>
                    <th class="text-center">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.OrderHistories)
                {
                    <tr>
                        <td class="text-center">@product.Date</td>
                        <td class="text-center">
                            <span style="font-size: 15px; white-space: normal" class="@product.StateClass">@product.StateDescription</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="row">
    <div class="form-group col-md-12 text-right">
        <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
    </div>
</div>

@section Scripts
{
    <script src="~/content/datatable/datatables.min.js"></script>

    <script>
        $(document).ready(function () {
            var grid = $('#Grid').DataTable({
                responsive: {
                    details: {
                        type: 'inline',
                        renderer: function (api, rowIdx, columns) {
                            var data = $.map(columns, function (col) {
                                return col.hidden
                                    ? `
                                        <div class="detail-item">
                                            <span class="detail-title">${col.title}:</span>
                                            <span class="detail-data">${col.data}</span>
                                        </div>
                                        `
                                    : '';
                            }).join('');
                            return data ? `<div class="details-container">${data}</div>` : false;
                        }
                    }
                },
                "paging": false,
                
                "searching": false,
                "ordering": false,
                "info": false,
                "autoWidth": false,
                "columns": [
                    { "responsivePriority": 1, "className": "text-center" },
                    { "responsivePriority": 4, "className": "text-center" },
                    { "responsivePriority": 1, "className": "text-center" },
                    { "responsivePriority": 1, "className": "text-center" },
                ],
                "language": {
                    "decimal": ",",
                    "emptyTable": "No hay datos disponibles en la tabla",
                    "info": "_START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "0 a 0 de 0 registros",
                    "infoFiltered": "(filtrado de _MAX_ registros en total)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Mostrar _MENU_ registros",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "searchPlaceholder": "Buscar...",
                    "zeroRecords": "No se encontraron registros coincidentes",
                    "paginate": {
                        "first": "<<",
                        "last": ">>",
                        "next": ">",
                        "previous": "<"
                    }
                }
            });
        })
    </script>
}