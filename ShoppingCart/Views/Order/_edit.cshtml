@model Service.Data.OrderData

<div class="col-lg-12" style="overflow: auto">
    <table class="table table-striped table-bordered table-hover" width="100%">
        <thead>
            <tr>
                <th class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">Nombre</th>
                <th class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">Cant.</th>
                <th class="text-center" style="width: 120px; max-width: 120px; min-width: 120px">Precio U.</th>
                <th class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">% Iva</th>
                <th class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">Total</th>
                <th class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @for (int productIndex = 0; productIndex < Model.Products.Count; productIndex++)
            {
                <tr>
                    @Html.HiddenFor(model => model.Products[productIndex].Id)
                    @Html.HiddenFor(model => model.Products[productIndex].ProductId)
                    @Html.HiddenFor(model => model.Products[productIndex].UnitPrice)
                    @Html.HiddenFor(model => model.Products[productIndex].Name)
                    <td class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">
                        @Html.DisplayFor(model => model.Products[productIndex].Name)
                    </td>
                    <td class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">
                        @Html.EditorFor(model => model.Products[productIndex].Quantity, new
                            {
                                htmlAttributes = new
                                {
                                    @class = "text-center productInput number w-100",
                                    @step = "1",
                                    @min = "1",
                                    @pattern = "[0-9]*",
                                    onchange = $"updateOrder()"
                                }
                            })
                    </td>
                    <td class="text-center" style="width: 120px; max-width: 120px; min-width: 120px">
                        @Html.EditorFor(model => model.Products[productIndex].UnitPrice, new
                            {
                                htmlAttributes = new
                                {
                                    @class = "text-center productInput decimal w-100",
                                    @step = "1",
                                    @min = "1",
                                    @pattern = "[0-9]*",
                                    onchange = $"updateOrder()"
                                }
                            })
                    </td>
                    <td class="text-center" style="width: 80px; max-width: 80px; min-width: 80px">
                        @Html.EditorFor(model => model.Products[productIndex].IvaPercentage, new
                            {
                                htmlAttributes = new
                                {
                                    @class = "text-center productInput decimal w-100",
                                    @step = "1",
                                    @min = "1",
                                    @pattern = "[0-9]*",
                                    onchange = $"updateOrder()"
                                }
                            })
                    </td>
                    <td class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">
                        @Html.DisplayFor(model => model.Products[productIndex].DisplayTotal, new { @style = "font-size: larger" })
                    </td>
                    <td class="text-center" style="width: 100px; max-width: 100px; min-width: 100px">
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteProduct(@Model.Products[productIndex].ProductId)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="6">
                        No hay artículos
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="col-lg-12">
    <div class="card cart-summary shadow-sm border-0">
        <div class="card-body p-2" style="border: 2px solid #221109; border-bottom: none; background-color: #221109 !important; color: #FFD700 !important;">
            <div class="row align-items-center">
                <div class="col-md-4 text-center" style="font-size: 22px; font-weight: 800">
                    <strong class="me-3">Neto:</strong>
                    <span>
                        @Html.DisplayFor(model => model.NetDisplay)
                    </span>
                </div>
                <div class="col-md-4 text-center" style="font-size: 22px; font-weight: 800">
                    <strong class="me-3">Iva:</strong>
                    <span>
                        @Html.DisplayFor(model => model.IvaDisplay)
                    </span>
                </div>
                <div class="col-md-4 text-center" style="font-size: 22px; font-weight: 800">
                    <strong class="me-3">Total:</strong>
                    <span>
                        @Html.DisplayFor(model => model.TotalDisplay)
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>