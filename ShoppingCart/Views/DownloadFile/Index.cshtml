@using Model.Domain
@model Service.Data.DownloadFileData

@{
    ViewBag.Title = "Index";
}

@section Styles
{
    <link href="~/content/datatable/datatables.min.css" rel="stylesheet">
    <link href="~/content/sweet-alert2/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/css/tables.css" rel="stylesheet">
}

<div class="row">
    <div class="col-md-12">
        <h4 class="page-title text-center">ARCHIVOS</h4>
    </div>
</div>
<div class="row mb-3">
    <div class="col-md-12">
        <div id="partialMessages" style="height:40px">
            @await Html.PartialAsync("_Messages")
        </div>
    </div>
</div>
@using (Html.BeginForm("Create", "DownloadFile", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <div class="row">
        <div class="col-md-12">
            <h5 class="page-title-sm text-center">PDF</h5>
        </div>
        <div class="col-md-12">
            <h6>* El orden en la pantalla de archivos será descendente, es decir, el de mayor orden aquí será primero en la otra.</h6>
        </div>
    </div>
    <div class="row">
        @Html.Hidden("FileExtension", eFileExtension.Pdf)
        <div class="col-md-6 form-group">
            @Html.LabelFor(model => model.File)
            @Html.TextBoxFor(model => model.File, new { type = "file", @class = "form-control", accept = ".pdf" })
            @Html.ValidationMessageFor(model => model.File, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3 form-group">
            @Html.LabelFor(model => model.Order)
            @Html.EditorFor(Model => Model.Order, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Order, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3 form-group mt-md-3">
            <button type="submit" class="btn btn-primary mt-md-3">Agregar <i class="fa-solid fa-upload"></i></button>
        </div>
    </div>
}
<div class="row mb-4">
    <div class="col-md-12">
        <table id="PdfGrid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Orden</th>
                    <th class="text-center">Nombre</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
@using (Html.BeginForm("Create", "DownloadFile", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <div class="row">
        <div class="col-md-12">
            <h5 class="page-title-sm text-center">EXCEL (XLSX)</h5>
        </div>
        <div class="col-md-12">
            <h6>* El orden en la pantalla de archivos será descendente, es decir, el de mayor orden aquí será primero en la otra.</h6>
        </div>
    </div>
    <div class="row">
        @Html.Hidden("FileExtension", eFileExtension.Xlsx)
        <div class="col-md-6 form-group">
            @Html.LabelFor(model => model.File)
            @Html.TextBoxFor(model => model.File, new { type = "file", @class = "form-control", accept = ".xlsx" })
            @Html.ValidationMessageFor(model => model.File, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3 form-group">
            @Html.LabelFor(model => model.Order)
            @Html.EditorFor(Model => Model.Order, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Order, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3 form-group mt-md-3">
            <button type="submit" class="btn btn-primary mt-md-3">Agregar <i class="fa-solid fa-upload"></i></button>
        </div>
    </div>
}
<div class="row">
    <div class="col-md-12 mb-4">
        <table id="XlsxGrid" class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Orden</th>
                    <th class="text-center">Nombre</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts
{
    <script src="~/content/datatable/datatables.min.js"></script>
    <script src="~/content/sweet-alert2/js/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function () {
            var pdfGrid = $('#PdfGrid').DataTable({
                "processing": true,
                "serverSide": true,
                responsive: {
                    details: {
                        type: 'inline',
                        renderer: function (api, rowIdx, columns) {
                            var data = $.map(columns, function (col) {
                                return col.hidden
                                    ? `
                                <div class="detail-item">
                                    <span class="detail-title">${col.title}:</span>
                                    <span class="detail-data">${col.data}</span>
                                </div>
                                `
                                    : '';
                            }).join('');
                            return data ? `<div class="details-container">${data}</div>` : false;
                        }
                    }
                },
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("Grid")?fileExtensionId=" + '@((short)eFileExtension.Pdf)',
                    "type": "POST",
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) { return data = JSON.stringify(data); }
                },
                "order": [[0, "desc"]],
                "columns": [
                    { "data": "Order", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Name", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Actions", "responsivePriority": 1, "className": "text-center" },
                ],
                "language": {
                    "decimal": ",",
                    "emptyTable": "No hay datos disponibles en la tabla",
                    "info": "_START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "0 a 0 de 0 registros",
                    "infoFiltered": "(filtrado de _MAX_ registros en total)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Mostrar _MENU_ registros",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "searchPlaceholder": "Buscar...",
                    "zeroRecords": "No se encontraron registros coincidentes",
                    "paginate": {
                        "first": "<<",
                        "last": ">>",
                        "next": ">",
                        "previous": "<"
                    }
                },
                "columnDefs": [
                    {
                        "targets": [0],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var order = "<input onchange='updateOrder(this, " + rowData.Id + ")' class='form-control' type='number' step='1' min='1' pattern='[0-9]*' value='" +  rowData.Order + "'>";
                            $(td).empty();
                            $(td).css("text-align", "center");
                            $(td).append(order);
                        }
                    },
                    {
                        "targets": [-1],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var del = "<button type='button' class='btn btn-sm btn-danger mb-1 mr-1' title='Eliminar archivo' onclick='deleteElement(" + rowData.Id + ")'> Eliminar</button>";
                            $(td).css("text-align", "center");
                            $(td).append(del);
                        }
                    }
                ]
            });

            $("#Grid_filter input")
                .unbind()
                .bind("input", function (e) {
                    if (this.value.length >= 3) {
                        pdfGrid.search(this.value).draw();
                    }
                    if (this.value == "") {
                        pdfGrid.search("").draw();
                    }
                    return;
                });

            var xlsxGrid = $('#XlsxGrid').DataTable({
                "processing": true,
                "serverSide": true,
                responsive: {
                    details: {
                        type: 'inline',
                        renderer: function (api, rowIdx, columns) {
                            var data = $.map(columns, function (col) {
                                return col.hidden
                                    ? `
                                        <div class="detail-item">
                                            <span class="detail-title">${col.title}:</span>
                                            <span class="detail-data">${col.data}</span>
                                        </div>
                                        `
                                    : '';
                            }).join('');
                            return data ? `<div class="details-container">${data}</div>` : false;
                        }
                    }
                },
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "ajax": {
                    "url": "@Url.Action("Grid")?fileExtensionId=" + '@((short)eFileExtension.Xlsx)',
                    "type": "POST",
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) { return data = JSON.stringify(data); }
                },
                "order": [[0, "desc"]],
                "columns": [
                    { "data": "Order", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Name", "responsivePriority": 1, "className": "text-center" },
                    { "data": "Actions", "responsivePriority": 1, "className": "text-center" },
                ],
                "language": {
                    "decimal": ",",
                    "emptyTable": "No hay datos disponibles en la tabla",
                    "info": "_START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "0 a 0 de 0 registros",
                    "infoFiltered": "(filtrado de _MAX_ registros en total)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Mostrar _MENU_ registros",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "searchPlaceholder": "Buscar...",
                    "zeroRecords": "No se encontraron registros coincidentes",
                    "paginate": {
                        "first": "<<",
                        "last": ">>",
                        "next": ">",
                        "previous": "<"
                    }
                },
                "columnDefs": [
                    {
                        "targets": [0],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var order = "<input onchange='updateOrder(this, " + rowData.Id + ")' class='form-control' type='number' step='1' min='1' pattern='[0-9]*' value='" + rowData.Order + "'>";
                            $(td).empty();
                            $(td).css("text-align", "center");
                            $(td).append(order);
                        }
                    },
                    {
                        "targets": [-1],
                        "orderable": false,
                        "createdCell": function (td, cellData, rowData, row, col) {
                            var del = "<button type='button' class='btn btn-sm btn-danger mb-1 mr-1' title='Eliminar archivo' onclick='deleteElement(" + rowData.Id + ")'> Eliminar</button>";
                            $(td).css("text-align", "center");
                            $(td).append(del);
                        }
                    }
                ]
            });

            $("#Grid_filter input")
                .unbind()
                .bind("input", function (e) {
                    if (this.value.length >= 3) {
                        xlsxGrid.search(this.value).draw();
                    }
                    if (this.value == "") {
                        xlsxGrid.search("").draw();
                    }
                    return;
                });
        });

        function updateOrder(elem, id) {
            var order = elem.value;
            $.ajax({
                url: '@Url.Action("UpdateOrder")?id=' + id + '&order=' + order,
                type: 'POST',
                success: function (result) {
                    if(result){
                        $(elem).val(order);
                        $('#XlsxGrid').DataTable().draw();
                        $('#PdfGrid').DataTable().draw();
                        Swal.fire({
                            icon: 'success',
                            title: 'Éxito',
                            text: 'Orden actualizado con éxito',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    }else{
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'No se ha podido actualizar el orden',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'No se ha podido actualizar el orden',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            });
        }

        function deleteElement(id) {
            Swal.fire({
                title: "¿Está seguro de eliminar este item?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Aceptar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: {
                    confirmButton: 'btn btn-success', 
                    cancelButton: 'btn btn-danger mr-2'    
                },
                buttonsStyling: false,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")?id=' + id,
                        type: 'POST',
                        success: function (result) {
                            if(result){
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Éxito',
                                    text: 'Se ha eliminado correctamente el item',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                                $('#XlsxGrid').DataTable().draw();
                                $('#PdfGrid').DataTable().draw();
                            }else{
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'No se ha podido eliminar el item',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'No se ha podido eliminar el item',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    });
                }
            });
        }
    </script>
}