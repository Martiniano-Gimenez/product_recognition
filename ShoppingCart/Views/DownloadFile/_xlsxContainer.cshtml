@using Service.Data;
@model DownloadFileDisplayData

@{
    int offsetXlsx = ViewBag.OffsetXlsx;
}

@foreach (var file in Model.Xlsxs.List)
{
    <div class="list-group-item d-flex justify-content-between align-items-center bg-light text-dark mb-2 rounded shadow-sm">
        <span class="text-truncate w-75" title="@file.Name">
            <i class="fa-solid fa-file-excel text-success me-2 mr-2" style="font-size: 25px;"></i>@file.Name
        </span>
        <button type="button" onclick="downloadFile(@file.Id)" class="btn btn-sm btn-outline-success" title="Descargar">
            <i class="fa-solid fa-download"></i>
        </button>
    </div>
}
@if (!Model.Xlsxs.List.Any())
{
    <h5>No hay archivos xlsx disponibles</h5>
}
@if (Model.Xlsxs.Count - offsetXlsx > 0)
{
    <button type="button" id="xlsxFilePreviousBtn" onclick="loadPrevious(null, @offsetXlsx, '#xlsxFilePreviousBtn', '#xlsxContainer')" class="btn btn-success w-100">Ver más <i class="fa-solid fa-circle-plus"></i></button>
}
