@using Service.Data;
@model DownloadFileDisplayData

@{
    int offsetPdf = ViewBag.OffsetPdf;
}

@foreach (var file in Model.Pdfs.List)
{
    <div class="list-group-item d-flex justify-content-between align-items-center bg-light text-dark mb-2 rounded shadow-sm">
        <span class="text-truncate w-75" title="@file.Name">
            <i class="fa-solid fa-file-pdf text-danger me-2 mr-2" style="font-size: 25px;"></i>@file.Name
        </span>
        <button type="button" onclick="downloadFile(@file.Id)" class="btn btn-sm btn-outline-danger" title="Descargar">
            <i class="fa-solid fa-download"></i>
        </button>
    </div>
}
@if (!Model.Pdfs.List.Any())
{
    <h5>No hay archivos pdf disponibles</h5>
}
@if (Model.Pdfs.Count - offsetPdf > 0)
{
    <button type="button" id="pdfFilePreviousBtn" onclick="loadPrevious(@offsetPdf, null, '#pdfFilePreviousBtn', '#pdfContainer')" class="btn btn-danger w-100">Ver más <i class="fa-solid fa-circle-plus"></i></button>
}