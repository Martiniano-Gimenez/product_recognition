@using Model.Domain
@model Service.Data.ProductViewData


@{
    ViewBag.Title = "Detail";
    var controllerName = ViewContext.RouteData.Values["controller"].ToString();
}

@section Styles
{
    <link href="~/css/tables.css" rel="stylesheet">
}

<div class="row">
    <div class="col-md-12">
        <h4 class="page-title text-center">ARTÍCULO</h4>
    </div>
</div>
<div class="row mt-2">
    <div class="form-group col-md-6">
        @Html.LabelFor(model => model.Code)
        @Html.EditorFor(Model => Model.Code, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
    </div>
    <div class="form-group col-md-6">
        @Html.LabelFor(model => model.Name)
        @Html.EditorFor(Model => Model.Name, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
    </div>
</div>
<div class="row mt-2">
    <div class="form-group col-md-6">
        @Html.LabelFor(model => model.SalePrice)
        @Html.EditorFor(Model => Model.SalePriceDisplay, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
    </div>
    <div class="form-group col-md-6">
        @Html.LabelFor(model => model.IvaPercentage)
        @Html.EditorFor(Model => Model.IvaPercentage, new { htmlAttributes = new { @class = "form-control", @disabled = "disabled" } })
    </div>
</div>
<div class="row mt-2">
    <div class="form-group col-md-12">
        @Html.LabelFor(model => model.Description)
        @Html.TextAreaFor(Model => Model.Description, new { @class = "form-control w-100", @style = "resize: none", @disabled = "disabled" })
    </div>
</div>
<hr />
<div class="row">
    <div class="col-md-12">
        <h5 class="page-title-sm text-center">OFERTAS</h5>
    </div>
</div>
<div class="row mt-1" style="overflow: auto">
    <div class="form-group col-md-12">
        <table class="table table-striped table-bordered table-hover" width="100%">
            <thead>
                <tr>
                    <th class="text-center">Unidades</th>
                    <th class="text-center">Precio Unitario</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ProductOffers.Any())
                {
                    for (int i = 0; i < Model.ProductOffers.Count; i++)
                    {
                        <tr>
                            <td class="text-center">
                                @Html.HiddenFor(model => model.ProductOffers[i].Units)
                                @Html.DisplayFor(model => model.ProductOffers[i].Units)
                            </td>
                            <td class="text-center">
                                @Html.HiddenFor(model => model.ProductOffers[i].DisplayUnitPrice)
                                @Html.DisplayFor(model => model.ProductOffers[i].DisplayUnitPrice)
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="3">Sin ofertas</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="row">
    <div class="form-group col-md-12 text-right mb-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
    </div>
</div>